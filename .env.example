# Mike / OpenClaw
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_CHAT_COMPLETIONS_URL=http://127.0.0.1:18789/v1/chat/completions
OPENCLAW_API_KEY=replace-with-openclaw-api-key
OPENCLAW_AGENT_ID=main
OPENCLAW_MODEL=gpt-4o-mini
CLAWBOT_DISPLAY_NAME=Mike
CLAWBOT_PROFILE_ID=00000000-0000-0000-0000-000000000000
CLAWBOT_SESSION_PREFIX=team-channel
# Optional frontend toggle: auto reply to every team message (without @Mike mention)
VITE_CLAWBOT_AUTO_REPLY=false

# Meta OAuth (Project Integrations)
META_APP_MARKETING_ID=123456789012345
META_APP_MARKETING_SECRET=replace-with-meta-marketing-app-secret
# Backward compatible fallback:
# META_APP_ID=123456789012345
# META_APP_SECRET=replace-with-meta-app-secret
META_GRAPH_VERSION=v21.0
META_OAUTH_STATE_SECRET=replace-with-long-random-secret
META_OAUTH_SCOPES=pages_show_list,pages_read_engagement,read_insights,pages_manage_posts,ads_read,ads_management,business_management,instagram_basic,instagram_content_publish,instagram_manage_insights

# Blotato API (Social Media Publishing)
