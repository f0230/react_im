{
  "buildCommand": "bash vercel-build.sh",
  "installCommand": "npm install --no-audit --no-fund && npm rebuild sharp",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "unsafe-none"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "unsafe-none"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "grupodte.com"
        }
      ],
      "destination": "https://www.grupodte.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/reports-ingest",
      "destination": "/api/reports?action=reports-ingest"
    },
    {
      "source": "/api/reports-ai-context",
      "destination": "/api/reports?action=reports-ai-context"
    },
    {
      "source": "/api/reports-ocr-summary",
      "destination": "/api/reports?action=reports-ingest"
    },
    {
      "source": "/api/cal/:action",
      "destination": "/api/cal?action=:action"
    },
    {
      "source": "/api/meta/:action",
      "destination": "/api/meta?action=:action"
    },
    {
      "source": "/api/whatsapp-send",
      "destination": "/api/whatsapp?action=send"
    },
    {
      "source": "/api/whatsapp-webhook",
      "destination": "/api/whatsapp?action=webhook"
    },
    {
      "source": "/api/whatsapp-ai-toggle",
      "destination": "/api/whatsapp?action=ai-toggle"
    },
    {
      "source": "/api/figma-auth/login",
      "destination": "/api/figma?action=auth-login"
    },
    {
      "source": "/api/figma-auth/callback",
      "destination": "/api/figma?action=auth-callback"
    },
    {
      "source": "/api/figma-webhook",
      "destination": "/api/figma?action=webhook"
    },
    {
      "source": "/api/figma/comments",
      "destination": "/api/figma?action=comments"
    },
    {
      "source": "/api/client-welcome-email",
      "destination": "/api/notifications?action=welcome-email"
    },
    {
      "source": "/api/project-created",
      "destination": "/api/notifications?action=project-created"
    },
    {
      "source": "/api/slack-notify",
      "destination": "/api/notifications?action=slack-notify"
    },
    {
      "source": "/((?!api/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}